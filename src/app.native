<!-- v1 dashboard placeholder: the tach-cluster popover lands with the
     NSPopover host patch. Live-reloads in dev: edit while running.
     Validate with: native markup check src/app.native -->
<column gap="14" padding="18">
  <row gap="8" cross="center">
    <text grow="1" size="lg">{glance_text}</text>
  </row>
  <column gap="6">
    <text>{claude_text}</text>
    <text>{codex_text}</text>
  </column>
  <text size="sm">{today_text}</text>
  <status-bar>{status_text}</status-bar>
</column>
