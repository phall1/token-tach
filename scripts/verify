#!/bin/zsh
# token-tach verify harness — the dev loop in one command.
#   1. native check   — markup/manifest/binding validation (ms)
#   2. native test    — headless unit + model-contract tests
#   3. native build   — automation-enabled ReleaseFast binary
#   4. smoke drive    — launch app, snapshot a11y tree, toggle the tray
#                       popover, assert state, screenshot, kill
# Usage: scripts/verify [--no-smoke]
set -e
unsetopt bg_nice 2>/dev/null || true
cd "$(dirname "$0")/.."

# The app.zon uses `.macos` (accessory mode), which the stock npm CLI
# cannot parse — prefer the CLI built from the vendored fork.
# scripts/setup builds it; NATIVE_BIN overrides.
NATIVE="${NATIVE_BIN:-vendor/native/zig-out/bin/native}"
[[ -x "$NATIVE" ]] || NATIVE=native
echo "==> using $($NATIVE --version)"

echo "==> native check"
$NATIVE check

echo "==> native test"
$NATIVE test

echo "==> native build (-Dautomation=true)"
$NATIVE build -Dautomation=true

if [[ "$1" == "--no-smoke" ]]; then
  echo "==> smoke skipped"
  exit 0
fi

echo "==> smoke drive"
pkill -f zig-out/bin/token-tach 2>/dev/null || true
sleep 0.5
./zig-out/bin/token-tach >/dev/null 2>&1 &
APP_PID=$!
cleanup() { kill $APP_PID 2>/dev/null || true }
trap cleanup EXIT

# wait for automation socket
for i in {1..20}; do
  $NATIVE automate list >/dev/null 2>&1 && break
  sleep 0.25
done

SNAP=$($NATIVE automate snapshot 2>/dev/null)
# Popover-hosted: the window exists but stays hidden until toggled.
echo "$SNAP" | grep -q 'popover_window="main"' || { echo "FAIL: tray popover binding missing"; exit 1 }

# Toggle the popover open and assert the dashboard rendered.
$NATIVE automate native-command native-sdk.tray.toggle-popover >/dev/null 2>&1 || true
sleep 1
SNAP=$($NATIVE automate snapshot 2>/dev/null)
echo "$SNAP" | grep -q 'popover_visible=true' || { echo "FAIL: popover did not open"; exit 1 }
echo "$SNAP" | grep -q 'today \$' || { echo "FAIL: today line missing from snapshot"; exit 1 }
echo "$SNAP" | grep -q 'models priced\|starting\|scanning' || { echo "FAIL: status line missing"; exit 1 }

# Give the first 2s sweep a chance to run, then confirm the app survived it.
sleep 3
$NATIVE automate snapshot 2>/dev/null | grep -q 'today \$' || { echo "FAIL: app died or blanked after first sweep"; exit 1 }
$NATIVE automate screenshot main-canvas >/dev/null 2>&1 || true

# Open the model-declared dashboard window and assert its canvas tree exists.
$NATIVE automate native-command tach.dashboard >/dev/null 2>&1 || true
sleep 1
SNAP=$($NATIVE automate snapshot 2>/dev/null)
echo "$SNAP" | grep -q 'dashboard-canvas' || { echo "FAIL: dashboard window missing"; exit 1 }
echo "$SNAP" | grep -q 'Token Tach dashboard' || { echo "FAIL: dashboard semantics missing"; exit 1 }
$NATIVE automate screenshot dashboard-canvas >/dev/null 2>&1 || true

# Close the round trip. The dashboard window may have stolen focus and
# auto-closed the transient popover already — check state before toggling
# so we assert "ends closed", not a blind toggle count.
if $NATIVE automate snapshot 2>/dev/null | grep -q 'popover_visible=true'; then
  $NATIVE automate native-command native-sdk.tray.toggle-popover >/dev/null 2>&1 || true
  sleep 1
fi
$NATIVE automate snapshot 2>/dev/null | grep -q 'popover_visible=false' || { echo "FAIL: popover did not close"; exit 1 }

echo "==> smoke drive: PASS"
echo "VERIFY: ALL GREEN"
