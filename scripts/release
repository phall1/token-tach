#!/bin/zsh
# token-tach release build: verify -> package -> sign -> (optionally) notarize.
#
# Usage:
#   scripts/release                     # adhoc-signed .app + dmg (local use)
#   scripts/release --identity "Developer ID Application: ..." [--team-id XXX] [--notarize]
#
# Notarization needs a notarytool keychain profile named "token-tach"
# (xcrun notarytool store-credentials token-tach --apple-id ... --team-id ...).
set -e
cd "$(dirname "$0")/.."

# app.zon uses `.macos` — needs the fork-built CLI (see scripts/setup).
NATIVE="${NATIVE_BIN:-vendor/native/zig-out/bin/native}"
[[ -x "$NATIVE" ]] || NATIVE=native

IDENTITY=""
TEAM_ID=""
NOTARIZE=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --identity) IDENTITY="$2"; shift 2 ;;
    --team-id)  TEAM_ID="$2"; shift 2 ;;
    --notarize) NOTARIZE=1; shift ;;
    *) echo "unknown arg: $1"; exit 2 ;;
  esac
done

echo "==> verify (no smoke)"
scripts/verify --no-smoke

# verify leaves an automation-enabled binary in zig-out/bin — that build
# writes its automation socket to a RELATIVE path and dies with
# ReadOnlyFileSystem when launched from Finder (cwd=/). Package a clean
# production build instead.
echo "==> production build (no automation)"
$NATIVE build

echo "==> package"
ARGS=(--target macos --archive)
if [[ -n "$IDENTITY" ]]; then
  ARGS+=(--signing identity --identity "$IDENTITY")
  [[ -n "$TEAM_ID" ]] && ARGS+=(--team-id "$TEAM_ID")
else
  ARGS+=(--signing adhoc)
  echo "    (adhoc signing — pass --identity for a distributable build)"
fi
$NATIVE package "${ARGS[@]}"

APP=$(ls -d zig-out/package/*.app 2>/dev/null | head -1 || true)
DMG=$(ls zig-out/package/*.dmg 2>/dev/null | head -1 || true)
[[ -n "$APP" ]] && echo "==> app: $APP"
[[ -n "$DMG" ]] && echo "==> dmg: $DMG"

# Launch sanity: Finder launches with cwd=/ — the packaged app must
# survive that (an automation build dies on its relative socket path).
echo "==> launch check (cwd=/)"
BIN="$(pwd)/$(ls "$APP"/Contents/MacOS/* | head -1)"
( cd / && "$BIN" >/dev/null 2>&1 ) &
CHECK_PID=$!
sleep 3
if kill -0 $CHECK_PID 2>/dev/null; then
  kill $CHECK_PID 2>/dev/null || true
  echo "==> launch check: PASS"
else
  echo "FAIL: packaged app exited within 3s when launched from cwd=/"
  exit 1
fi

if [[ "$NOTARIZE" == 1 ]]; then
  [[ -n "$IDENTITY" ]] || { echo "FAIL: --notarize requires --identity"; exit 1 }
  [[ -n "$DMG" ]] || { echo "FAIL: no dmg produced to notarize"; exit 1 }
  echo "==> notarize"
  xcrun notarytool submit "$DMG" --keychain-profile token-tach --wait
  xcrun stapler staple "$DMG"
  echo "==> notarized + stapled"
fi

echo "RELEASE: done"
