#!/bin/zsh
# Validate, upload, monitor, and optionally assign a Mac App Store build.
set -euo pipefail

cd "$(dirname "$0")/.."

COMMAND="${1:-}"
[[ -n "$COMMAND" ]] && shift
BUNDLE_ID="com.phall.token-tach"
API_BASE="https://api.appstoreconnect.apple.com/v1"
TMP_DIR=$(mktemp -d "${TMPDIR:-/tmp}/token-tach-asc.XXXXXX")
trap 'rm -rf "$TMP_DIR"' EXIT

usage() {
  print -u2 "usage: scripts/app-store-connect next-build-number"
  print -u2 "       scripts/app-store-connect deliver package.pkg --build-number N [--testflight-group NAME] [--timeout SECONDS]"
}

require_credentials() {
  : "${APP_STORE_CONNECT_API_KEY_ID:?APP_STORE_CONNECT_API_KEY_ID is required}"
  : "${APP_STORE_CONNECT_API_ISSUER_ID:?APP_STORE_CONNECT_API_ISSUER_ID is required}"
  : "${APP_STORE_CONNECT_APP_ID:?APP_STORE_CONNECT_APP_ID is required}"
  : "${APP_STORE_CONNECT_API_KEY_PATH:?APP_STORE_CONNECT_API_KEY_PATH is required}"
  [[ -f "$APP_STORE_CONNECT_API_KEY_PATH" ]] || { print -u2 "API key file not found"; exit 1; }
  command -v jq >/dev/null || { print -u2 "jq is required"; exit 1; }
}

api_get() {
  local endpoint="$1"
  shift
  local token response status
  token=$(scripts/app-store-connect-jwt.rb)
  response="$TMP_DIR/response.json"
  status=$(curl --silent --show-error --get --output "$response" --write-out '%{http_code}' \
    -H "Authorization: Bearer $token" -H 'Accept: application/json' \
    "$API_BASE$endpoint" "$@")
  if [[ "$status" -lt 200 || "$status" -ge 300 ]]; then
    print -u2 "App Store Connect GET $endpoint failed (HTTP $status):"
    jq . "$response" >&2 || /bin/cp "$response" /dev/stderr
    return 1
  fi
  /bin/cp "$response" /dev/stdout
}

api_post_json() {
  local endpoint="$1" json="$2"
  local token response status
  token=$(scripts/app-store-connect-jwt.rb)
  response="$TMP_DIR/response.json"
  status=$(curl --silent --show-error --output "$response" --write-out '%{http_code}' \
    -X POST -H "Authorization: Bearer $token" -H 'Content-Type: application/json' \
    --data "$json" "$API_BASE$endpoint")
  if [[ "$status" -lt 200 || "$status" -ge 300 ]]; then
    print -u2 "App Store Connect POST $endpoint failed (HTTP $status):"
    jq . "$response" >&2 || /bin/cp "$response" /dev/stderr
    return 1
  fi
  [[ -s "$response" ]] && /bin/cp "$response" /dev/stdout
}

next_build_number() {
  local versions prerelease_id response current version
  version=$(scripts/version current)
  versions=$(api_get /preReleaseVersions \
    --data-urlencode "filter[app]=$APP_STORE_CONNECT_APP_ID" \
    --data-urlencode "filter[version]=$version" \
    --data-urlencode 'filter[platform]=MAC_OS' \
    --data-urlencode 'limit=2')
  [[ $(print -r -- "$versions" | jq '.data | length') -le 1 ]] || {
    print -u2 "App Store Connect returned multiple macOS prereleases for $version"
    exit 1
  }
  prerelease_id=$(print -r -- "$versions" | jq -r '.data[0].id // empty')
  if [[ -z "$prerelease_id" ]]; then
    print 1
    return
  fi
  response=$(api_get /builds \
    --data-urlencode "filter[preReleaseVersion]=$prerelease_id" \
    --data-urlencode 'sort=-uploadedDate' \
    --data-urlencode 'limit=1')
  current=$(print -r -- "$response" | jq -r '.data[0].attributes.version // "0"')
  [[ "$current" == <-> ]] || { print -u2 "invalid build number returned by Apple: $current"; exit 1; }
  print -r -- "$(( 10#$current + 1 ))"
}

case "$COMMAND" in
  next-build-number)
    require_credentials
    next_build_number
    ;;
  deliver)
    PKG="${1:-}"
    [[ -n "$PKG" ]] && shift
    BUILD_NUMBER=""
    GROUP=""
    TIMEOUT=3600
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --build-number) BUILD_NUMBER="$2"; shift 2 ;;
        --testflight-group) GROUP="$2"; shift 2 ;;
        --timeout) TIMEOUT="$2"; shift 2 ;;
        *) print -u2 "unknown argument: $1"; usage; exit 2 ;;
      esac
    done
    [[ -f "$PKG" && -n "$BUILD_NUMBER" ]] || { usage; exit 2; }
    [[ "$TIMEOUT" == <-> ]] || { print -u2 "timeout must be seconds"; exit 2; }
    require_credentials

    # altool discovers API keys only in a few fixed directories. Use an
    # ephemeral working directory and never place key material in the checkout.
    mkdir -m 700 "$TMP_DIR/private_keys"
    /bin/cp "$APP_STORE_CONNECT_API_KEY_PATH" "$TMP_DIR/private_keys/AuthKey_${APP_STORE_CONNECT_API_KEY_ID}.p8"
    chmod 600 "$TMP_DIR/private_keys/AuthKey_${APP_STORE_CONNECT_API_KEY_ID}.p8"
    ABS_PKG="${PKG:A}"
    print "==> Apple preflight validation"
    (cd "$TMP_DIR" && xcrun altool --validate-app --file "$ABS_PKG" --type macos \
      --apiKey "$APP_STORE_CONNECT_API_KEY_ID" --apiIssuer "$APP_STORE_CONNECT_API_ISSUER_ID") 2>&1 | tee "$TMP_DIR/validate.log"
    print "==> upload build $BUILD_NUMBER"
    (cd "$TMP_DIR" && xcrun altool --upload-app --file "$ABS_PKG" --type macos \
      --apiKey "$APP_STORE_CONNECT_API_KEY_ID" --apiIssuer "$APP_STORE_CONNECT_API_ISSUER_ID") 2>&1 | tee "$TMP_DIR/upload.log"

    print "==> wait for App Store Connect processing"
    deadline=$(( EPOCHSECONDS + TIMEOUT ))
    BUILD_ID=""
    state="not found"
    while (( EPOCHSECONDS < deadline )); do
      response=$(api_get /builds \
        --data-urlencode "filter[app]=$APP_STORE_CONNECT_APP_ID" \
        --data-urlencode "filter[version]=$BUILD_NUMBER" \
        --data-urlencode 'sort=-uploadedDate' \
        --data-urlencode 'limit=1')
      BUILD_ID=$(print -r -- "$response" | jq -r '.data[0].id // empty')
      state=$(print -r -- "$response" | jq -r '.data[0].attributes.processingState // "AWAITING_UPLOAD"')
      print "    processing state: $state"
      case "$state" in
        VALID) break ;;
        INVALID)
          print -u2 "Apple marked the build INVALID:"
          print -r -- "$response" | jq '.data[0]' >&2
          print -u2 "Open App Store Connect > TestFlight > macOS > build $BUILD_NUMBER for Apple's processing diagnostics."
          exit 1
          ;;
      esac
      sleep 30
    done
    [[ -n "$BUILD_ID" && "$state" == "VALID" ]] || {
      print -u2 "timed out after ${TIMEOUT}s waiting for build $BUILD_NUMBER; last state: ${state:-not found}"
      exit 1
    }
    print "    processed build id: $BUILD_ID"

    if [[ -n "$GROUP" ]]; then
      print "==> assign internal TestFlight group: $GROUP"
      groups=$(api_get /betaGroups \
        --data-urlencode "filter[app]=$APP_STORE_CONNECT_APP_ID" \
        --data-urlencode "filter[name]=$GROUP" \
        --data-urlencode 'limit=2')
      count=$(print -r -- "$groups" | jq '.data | length')
      [[ "$count" == 1 ]] || { print -u2 "expected one TestFlight group named '$GROUP', found $count"; exit 1; }
      internal=$(print -r -- "$groups" | jq -r '.data[0].attributes.isInternalGroup')
      [[ "$internal" == true ]] || { print -u2 "refusing to assign external TestFlight group '$GROUP'"; exit 1; }
      group_id=$(print -r -- "$groups" | jq -r '.data[0].id')
      payload=$(jq -cn --arg id "$BUILD_ID" '{data:[{type:"builds",id:$id}]}')
      api_post_json "/betaGroups/$group_id/relationships/builds" "$payload" >/dev/null
      print "    assigned build $BUILD_NUMBER to $GROUP"
    fi
    print "APP STORE DELIVERY: processed successfully"
    print "Production review was not submitted. Final review submission remains manual in App Store Connect."
    ;;
  *) usage; exit 2 ;;
esac
