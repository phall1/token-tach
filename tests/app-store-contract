#!/bin/zsh
# Credential-free regression checks for Store-only runtime and release wiring.
set -euo pipefail
cd "$(dirname "$0")/.."

require_text() {
  grep -Fq -- "$2" "$1" || { print -u2 "FAIL: $1 lacks Store contract: $2"; exit 1; }
}

plutil -lint assets/mac-app-store.entitlements >/dev/null
require_text assets/mac-app-store.entitlements '<key>com.apple.security.app-sandbox</key>'
require_text assets/mac-app-store.entitlements '<key>com.apple.security.files.bookmarks.app-scope</key>'
require_text assets/mac-app-store.entitlements '<key>com.apple.security.files.user-selected.read-only</key>'
require_text src/engine.zig 'if (model.store_sandbox) return;'
require_text src/main.zig 'token_tach_macos_is_sandboxed()'
require_text src/main.zig '.store_sandbox = store_access.sandboxed'
require_text src/macos_store_access.m 'NSURLBookmarkCreationWithSecurityScope'
require_text src/macos_store_access.m 'startAccessingSecurityScopedResource'
require_text src/macos_store_access.m 'OpenCodeDataFolderBookmark'
require_text build.zig 'b.option(bool, "app-store"'

if grep -Eq 'security\.files\.user-selected\.read-write|network\.server|device\.' assets/mac-app-store.entitlements; then
  print -u2 "FAIL: Store entitlements gained a privileged capability"
  exit 1
fi

print "APP STORE CONTRACT: PASS"
